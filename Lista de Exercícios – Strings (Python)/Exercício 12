# Corrigir telefone: Leia um telefone com 7 ou 8 dígitos e ajuste adicionando o '3' se necessário
def corrigir_telefone(telefone):
    # 1. Limpar o input (remover espaços, traços ou parênteses)
    # Importante para garantir que contaremos apenas os números
    tel_limpo = str(telefone).replace("-", "").replace(" ", "").replace("(", "").replace(")", "")

    # 2. Verificar a quantidade de dígitos
    tamanho = len(tel_limpo)

    if tamanho == 7:
        # Adiciona o '3' na frente
        novo_tel = "3" + tel_limpo
        print(f"📞 Telefone ajustado: {novo_tel[:4]}-{novo_tel[4:]}")
        return novo_tel
    
    elif tamanho == 8:
        print(f"✅ Telefone já possui 8 dígitos: {tel_limpo[:4]}-{tel_limpo[4:]}")
        return tel_limpo
    
    else:
        print("⚠️ Formato inválido. Digite um número com 7 ou 8 dígitos.")
        return tel_limpo

# --- Teste no Terminal ---
entrada = input("Digite o telefone (7 ou 8 dígitos): ")
corrigir_telefone(entrada)