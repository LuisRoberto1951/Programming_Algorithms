# Converta um valor em Gigabytes para Megabytes e Kilobytes.

valorGigabytes = float(input("Digite o valor em Gigabytes: "))
valorMegabytes = valorGigabytes * 1024
valorKilobytes = valorGigabytes * 1024 * 1024
print(f"O valor em Megabytes é: {valorMegabytes}")
print(f"O valor em Kilobytes é: {valorKilobytes}")