# Entrada dos três lados
lado1 = float(input("Digite o primeiro lado: "))
lado2 = float(input("Digite o segundo lado: "))
lado3 = float(input("Digite o terceiro lado: "))

# 1. Verificação da existência do triângulo
# Regra: A soma de dois lados deve ser sempre maior que o terceiro
e_triangulo = (lado1 + lado2 > lado3) and \
              (lado1 + lado3 > lado2) and \
              (lado2 + lado3 > lado1)

if e_triangulo:
    print("\nOs valores informados FORMAM um triângulo.")
    
    # 2. Classificação do tipo de triângulo
    if lado1 == lado2 == lado3:
        tipo = "Equilátero"
        descricao = "Três lados iguais."
    elif lado1 == lado2 or lado1 == lado3 or lado2 == lado3:
        tipo = "Isósceles"
        descricao = "Dois lados iguais."
    else:
        tipo = "Escaleno"
        descricao = "Três lados diferentes."
        
    print(f"Tipo: {tipo} ({descricao})")

else:
    print("\nOs valores informados NÃO podem formar um triângulo.")
    print("Motivo: A soma de dois lados não é maior que o terceiro.")