# Faça um programa que peça uma data no formato dd/mm/aaaa e determine se a mesma é uma data válida.

data = input("Digite uma data no formato dd/mm/aaaa: ")

# Tenta separar a string por '/' e converter para inteiros
try:
    dia, mes, ano = map(int, data.split('/'))
    valida = False

    # 1. Verificação básica de meses e anos positivos
    if 1 <= mes <= 12 and ano > 0:
        
        # 2. Determinar o limite de dias do mês
        # Meses com 31 dias
        if mes in [1, 3, 5, 7, 8, 10, 12]:
            if 1 <= dia <= 31:
                valida = True
        
        # Meses com 30 dias
        elif mes in [4, 6, 9, 11]:
            if 1 <= dia <= 30:
                valida = True
        
        # Caso especial: Fevereiro
        elif mes == 2:
            # Verifica se o ano é bissexto
            if (ano % 4 == 0 and ano % 100 != 0) or (ano % 400 == 0):
                if 1 <= dia <= 29:
                    valida = True
            else:
                if 1 <= dia <= 28:
                    valida = True

    if valida:
        print(f"A data {data} é VÁLIDA. ✅")
    else:
        print(f"A data {data} é INVÁLIDA. ❌")

except ValueError:
    print("Formato inválido! Certifique-se de usar dd/mm/aaaa com números.")